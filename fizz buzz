#include <stdio.h>

int main() {
    int i, num;

    for(i = 1; i <= 10; i++) {
        printf("Enter number %d: ", i);
        scanf("%d", &num);

        if(num % 3 == 0 && num % 5 == 0) {
            printf("FizzBuzz\n");
        }
        else if(num % 3 == 0) {
            printf("Fizz\n");
        }
        else if(num % 5 == 0) {
            printf("Buzz\n");
        }
        else {
            printf("%d\n", num);
        }
    }

    return 0;
}
