#include <stdio.h>
#include <string.h>
int main() {
    char s1[]="listen", s2[]="silent";
    int freq[26]={0};
    for(int i=0;s1[i]!='\0';i++)
        freq[s1[i]-'a']++;
    for(int i=0;s2[i]!='\0';i++)
        freq[s2[i]-'a']--;
    int flag=1;
    for(int i=0;i<26;i++){
        if(freq[i]!=0){
            flag=0; break;
        }
    }
    if(flag) printf("Anagram");
    else printf("Not Anagram");
}
