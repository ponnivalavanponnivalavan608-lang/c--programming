#include <stdio.h>
int main() {
    char str[]="I love programming";
    int max=0,len=0;
    for(int i=0;str[i]!='\0';i++){
        if(str[i]!=' ') len++;
        else{
            if(len>max) max=len;
            len=0;
        }
    }
    if(len>max) max=len;
    printf("Longest length=%d", max);
}
