#include <stdio.h>

int main()
{
    int n, square, temp;

    printf("Enter a number: ");
    scanf("%d", &n);

    square = n * n;
    temp = n;

    while(temp > 0)
    {
        if(temp % 10 != square % 10)
        {
            printf("Not an Automorphic number");
            return 0;
        }
        temp = temp / 10;
        square = square / 10;
    }

    printf("Automorphic number");

    return 0;
}
