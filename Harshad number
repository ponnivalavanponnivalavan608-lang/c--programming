#include <stdio.h>

int main()
{
    int n, temp, sum = 0, digit;

    printf("Enter a number: ");
    scanf("%d", &n);

    temp = n;

    // Calculate sum of digits
    while(temp > 0)
    {
        digit = temp % 10;
        sum = sum + digit;
        temp = temp / 10;
    }

    // Check divisibility
    if(n % sum == 0)
        printf("%d is a Harshad (Niven) number", n);
    else
        printf("%d is not a Harshad (Niven) number", n);

    return 0;
}
