#include<stdio.h>
void main()
{
    char str[100];
    int i,letters=0,digits=0,special=0;

    printf("Enter string: ");
    scanf("%s",str);

    for(i=0;str[i]!='\0';i++){
        if((str[i]>='a'&&str[i]<='z')||(str[i]>='A'&&str[i]<='Z'))
            letters++;
        else if(str[i]>='0'&&str[i]<='9')
            digits++;
        else
            special++;
    }

    printf("Letters=%d Digits=%d Special=%d",letters,digits,special);
}
