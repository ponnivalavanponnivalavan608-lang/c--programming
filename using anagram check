#include<stdio.h>
#include<string.h>
void main()
{
    char s1[50],s2[50];
    int i,j;

    printf("Enter string1: ");
    scanf("%s",s1);

    printf("Enter string2: ");
    scanf("%s",s2);

    if(strlen(s1)!=strlen(s2)){
        printf("Not Anagram");
        return;
    }

    for(i=0;s1[i]!='\0';i++){
        for(j=i+1;s1[j]!='\0';j++){
            if(s1[i]>s1[j]){
                char t=s1[i]; s1[i]=s1[j]; s1[j]=t;
            }
        }
    }

    for(i=0;s2[i]!='\0';i++){
        for(j=i+1;s2[j]!='\0';j++){
            if(s2[i]>s2[j]){
                char t=s2[i]; s2[i]=s2[j]; s2[j]=t;
            }
        }
    }

    if(strcmp(s1,s2)==0)
        printf("Anagram");
    else
        printf("Not Anagram");
}
